type Foo = { val: string }

<Foo val="abc" />



enum Stage = intent_select | describe | clarify | collect_contact | ready | complete

enum Urgency = emergency | urgent | flexible
enum Intent = emergency_leak | toilet_issue | faucet_sink | shower_tub | water_heater | installation | other



type SourcedValue<T> {
    value: T
    confidence: float
    source: string
    lock: boolean
}


type FlowState = {
    intent: SourcedValue<Intent>
    problemText: SourcedValue<string>
    urgency: SourcedValue<Urgency>
    leakActive: SourcedValue<bool>
    photos: SourcedValue<Attachment[]>
    address: SourcedValue<Address>
    phone: SourcedValue<Phone>
    name: SourcedValue<string>
}


let <ChooseIntent /> =
  <ChoiceButtons prompt="What can we help with today?" bind={FlowState.intent}>
    <Choice label="🚨 Emergency / leak" value={Intent.emergency_leak} />
    <Choice label="🚽 Toilet issue" value={Intent.toilet_issue} />
    <Choice label="🚰 Faucet / sink" value={Intent.faucet_sink} />
    <Choice label="🚿 Shower / tub" value={Intent.shower_tub} />
    <Choice label="🔥 Water heater" value={Intent.water_heater} />
    <Choice label="🧰 Install / replace" value={Intent.installation} />
    <Choice label="❓ Something else" value={Intent.other} />
  </ChoiceButtons>




  
nextActions = (st) =>
  if st.stage == "intent_select" then
    [ { type: "ShowCard", card: cards.intent_buttons } ]

  else if st.stage == "describe" then
    [
      { type: "Say", text: "Briefly describe what’s going on." },
      { type: "ExpectUserMessage", hint: "free_text" }
    ]





  // ---------------------------------------------------------------------------
  // Stage advancement as updates (optional convenience)
  // ---------------------------------------------------------------------------
  stageAdvanceUpdates = (st) =>
    rules firstMatch {
      rule { when: st.stage == "intent_select" && has(st, "intent", null)
             then: [ update { stage := "describe" } ] }

      rule { when: st.stage == "describe" && has(st, "problem_text", 0.5)
             then: [ update { stage := "clarify" } ] }

      // After clarify requirements are met, go collect contact
      rule {
        when: st.stage == "clarify"
              && has(st, "urgency", 0.7)
              && !(has(st,"intent",null) && get(st,"intent").v == "emergency_leak" && !has(st,"leak_active",0.7))
        then: [ update { stage := "collect_contact" } ]
      }

      rule {
        when: st.stage == "collect_contact"
              && has(st, "address", 0.7)
              && has(st, "phone", 0.7)
        then: [ update { stage := "ready" } ]
      }

      rule { when: true then: [] }
    }




type Email = string where matches(r"^[^\s@]+@[^\s@]+\.[^\s@]+$")
type PositiveInt = int where between(12, 120)
type EvenInt = int where Mod(2) == 0

let <intent_buttons prop:SourcedValue<string is Email> /> =
  <Buttons prompt="What can we help with today?" update=Update(prop, $)>
    <Choice label="🚨 Emergency / leak" value=Intent.emergency_leak />
    <Choice label="🚽 Toilet issue" value=Intent.toilet_issue />
    <Choice label="🚰 Faucet / sink" value=Intent.faucet_sink />
    <Choice label="🚿 Shower / tub" value=Intent.shower_tub />
    <Choice label="🔥 Water heater" value=Intent.water_heater />
    <Choice label="🧰 Install / replace" value=Intent.installation />
    <Choice label="❓ Something else" value=Intent.other />
  </Buttons>


